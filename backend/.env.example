PORT=3000

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Meta Cloud API
META_ACCESS_TOKEN=your-meta-access-token
META_PHONE_NUMBER_ID=810594372145616
META_VERIFY_TOKEN=crownkey_verify_2026

# WhatsJet (alternative WhatsApp provider)
WJ_BASE=https://crownkey.online/api
WJ_UID=your-whatsjet-uid
WJ_TOKEN=your-whatsjet-token
# Set WA_PROVIDER=whatsjet to use WhatsJet instead of Meta Cloud API
WA_PROVIDER=meta

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Property Finder
PF_API_KEY=your-pf-api-key
PF_API_SECRET=your-pf-api-secret
